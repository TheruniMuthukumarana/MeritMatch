@page "/Student/Home"
@model HomeModel
@{
    ViewData["Title"] = "Student Home";
}

@functions {
    public string GetStatusColor(ProjectStatus status)
    {
        return status switch
        {
            ProjectStatus.Pending => "warning",
            ProjectStatus.Approved => "success",
            ProjectStatus.Rejected => "danger",
            ProjectStatus.UnderReview => "info",
            ProjectStatus.Matched => "primary",
            _ => "secondary"
        };
    }
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Proposals</h2>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newProposalModal">
            + New Proposal
        </button>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (Model.Proposals != null && Model.Proposals.Any())
    {
        <div class="row">
            @foreach (var proposal in Model.Proposals)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow h-100 border-0">
                        <div class="card-body pb-2">
                            <div class="d-flex align-items-center mb-2">
                                <span class="me-2" style="font-size:1.5rem; color:#6366f1;">
                                    <i class="bi bi-journal-text"></i>
                                </span>
                                <h5 class="card-title mb-0 flex-grow-1">@proposal.Title</h5>
                                <span class="badge bg-@GetStatusColor(proposal.Status) ms-2">@proposal.Status</span>
                            </div>
                            <div class="mb-2">
                                <span class="text-muted small"><i class="bi bi-diagram-3"></i> <strong>Research Area:</strong> @proposal.ResearchArea?.Name</span>
                            </div>
                            <div class="mb-2">
                                <span class="text-muted small"><i class="bi bi-tools"></i> <strong>Tech Stack:</strong> @proposal.TechStack</span>
                            </div>
                            <div class="mb-2">
                                <span class="text-muted small">
                                    <i class="bi bi-person-badge"></i>
                                    <strong>Supervisor:</strong>
                                    @(proposal.Supervisor != null ? proposal.Supervisor.Name : "Not Assigned")
                                </span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 d-flex justify-content-end pt-0">
                            <button type="button"
                                    class="btn btn-sm btn-outline-primary me-2"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editProposalModal"
                                    data-id="@proposal.Id"
                                    data-title="@proposal.Title"
                                    data-techstack="@proposal.TechStack"
                                    data-abstract="@proposal.Abstract">
                                <i class="bi bi-pencil"></i> Edit
                            </button>
                            <button type="button"
                                    class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteProposalModal"
                                    data-id="@proposal.Id">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">You have no proposals yet.</div>
    }
</div>

<!-- New Proposal Modal -->
<div class="modal fade" id="newProposalModal" tabindex="-1" aria-labelledby="newProposalModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 shadow">
            <form method="post" asp-page-handler="CreateProposal" autocomplete="off">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="newProposalModalLabel">Create New Proposal</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-2">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control rounded-3" id="Title" name="Title" placeholder="Title" required>
                        <label for="Title">Title</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control rounded-3" id="TechStack" name="TechStack" placeholder="Tech Stack" required>
                        <label for="TechStack">Tech Stack</label>
                    </div>
                    <div class="form-floating mb-3">
                        <textarea class="form-control rounded-3" id="Abstract" name="Abstract" placeholder="Abstract" style="height: 100px" required></textarea>
                        <label for="Abstract">Abstract</label>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Proposal Modal -->
<div class="modal fade" id="editProposalModal" tabindex="-1" aria-labelledby="editProposalModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 shadow">
            <form method="post" asp-page-handler="EditProposal" autocomplete="off">
                <input type="hidden" id="EditId" name="EditId" />
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="editProposalModalLabel">Edit Proposal</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-2">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control rounded-3" id="EditTitle" name="EditTitle" placeholder="Title" required>
                        <label for="EditTitle">Title</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control rounded-3" id="EditTechStack" name="EditTechStack" placeholder="Tech Stack" required>
                        <label for="EditTechStack">Tech Stack</label>
                    </div>
                    <div class="form-floating mb-3">
                        <textarea class="form-control rounded-3" id="EditAbstract" name="EditAbstract" placeholder="Abstract" style="height: 100px" required></textarea>
                        <label for="EditAbstract">Abstract</label>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Proposal Modal -->
<div class="modal fade" id="deleteProposalModal" tabindex="-1" aria-labelledby="deleteProposalModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 shadow">
            <form method="post" asp-page-handler="DeleteProposal">
                <input type="hidden" id="DeleteId" name="DeleteId" />
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="deleteProposalModalLabel">Delete Proposal</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-2">
                    <p>Are you sure you want to delete this proposal?</p>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger px-4">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- JavaScript to fill Edit and Delete Modals -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var editModal = document.getElementById('editProposalModal');
        if (editModal) {
            editModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                document.getElementById('EditId').value = button.getAttribute('data-id');
                document.getElementById('EditTitle').value = button.getAttribute('data-title');
                document.getElementById('EditTechStack').value = button.getAttribute('data-techstack');
                document.getElementById('EditAbstract').value = button.getAttribute('data-abstract');
            });
        }
        var deleteModal = document.getElementById('deleteProposalModal');
        if (deleteModal) {
            deleteModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                document.getElementById('DeleteId').value = button.getAttribute('data-id');
            });
        }
    });
</script>

